<!DOCTYPE html>
<html>
<head>
    <style>
        /* General Page Styling */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f4f8;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .container {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 450px;
            width: 90%;
        }

        h1 { color: #1e88e5; margin-bottom: 5px; }
        p { color: #64748b; margin-bottom: 25px; }

        /* Settings/Input Section */
        .settings {
            display: flex;
            gap: 15px;
            background: #e3f2fd;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 30px;
        }

        .input-group { text-align: left; flex: 1; }
        
        label { 
            font-size: 0.8rem; 
            font-weight: bold; 
            color: #1e88e5; 
            display: block;
            margin-bottom: 5px;
        }

        input {
            width: 100%;
            padding: 8px;
            border: 1px solid #bbdefb;
            border-radius: 6px;
            box-sizing: border-box;
        }

        /* Flashcard Styling */
        details {
            width: 100%;
            perspective: 1000px; /* For a 3D feel */
        }

        summary {
            list-style: none;
            cursor: pointer;
            outline: none;
        }

        /* Front of Card */
        .card-front, .card-back {
            padding: 60px 20px;
            border-radius: 15px;
            border: 2px solid;
            transition: transform 0.3s ease;
        }

        .card-front {
            background: #ffffff;
            border-color: #1e88e5;
        }

        .card-back {
            background: #e8f5e9;
            border-color: #43a047;
            margin-top: 10px; /* Slight gap when open */
            animation: slideDown 0.4s ease-out;
        }

        /* Text Styling inside Cards */
        .lang-label { font-size: 0.9rem; color: #94a3b8; letter-spacing: 2px; }
        .word { font-size: 2.5rem; display: block; margin: 10px 0; }
        .front-word { color: #1e88e5; }
        .back-word { color: #43a047; }
        .hint { font-size: 0.8rem; color: #f44336; font-style: italic; }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Language Pro</h1>
        <p>Master your vocabulary</p>

        <div class="settings">
            <div class="input-group">
                <label>ENGLISH</label>
                <input type="text" value="Hello">
            </div>
            <div class="input-group">
                <label>HINDI</label>
                <input type="text" value="नमस्ते">
            </div>
        </div>

        <details>
            <summary>
                <div class="card-front">
                    <span class="lang-label">ENGLISH</span>
                    <strong class="word front-word">Hello</strong>
                    <span class="hint">Click to Flip</span>
                </div>
            </summary>

            <div class="card-back">
                <span class="lang-label">HINDI</span>
                <strong class="word back-word">नमस्ते</strong>
                <span style="color: #43a047;">(Namaste)</span>
            </div>
        </details>
    </div>

</body>
</html>
